# Copy to .env (git-ignored — never commit). The gateway (service/app.py) auto-loads this
# file at startup via python-dotenv with override=False, so a real process env var always
# wins. Set EITHER OPENAI_API_KEY or GEMINI_API_KEY; you do not need both.

# EITHER this OR GEMINI_API_KEY. If set (and FABRI_LLM_PROVIDER unset) the agent runs on
# provider=openai, model gpt-4o, narrator gpt-4o-mini.
# OPENAI_API_KEY=sk-...

# Alternative to OPENAI_API_KEY. Also independently unlocks the real vid_ground_text vision
# grounding; without it the gateway auto-enables the offline stub (reduced accuracy, warned
# once at startup).
# GEMINI_API_KEY=...

# Optional: force the orchestrator provider instead of auto-pick (openai if OPENAI_API_KEY
# set, else gemini). One of: openai | gemini | anthropic | openrouter | bedrock.
# anthropic/openrouter/bedrock additionally REQUIRE FABRI_LLM_MODEL and the provider's own
# key env var (ANTHROPIC_API_KEY / OPENROUTER_API_KEY / AWS credential chain); the gateway
# always sends explicit model + api_key_env + narrator.model in its per-run overrides.
# FABRI_LLM_PROVIDER=openai

# Optional for openai/gemini (defaults gpt-4o / gemini-2.5-pro); REQUIRED for any other
# provider.
# FABRI_LLM_MODEL=gpt-4o

# Optional: cheap model for the live narration chat lines. Defaults: gpt-4o-mini (openai),
# gemini-2.5-flash-lite (gemini), else the main model. Always overridden per-run — the
# template narrator would otherwise send a Gemini model id to a non-Gemini provider and every
# narration line would silently vanish.
# FABRI_LLM_NARRATOR_MODEL=gpt-4o-mini

# Comma-separated EXACT browser origins allowed to call the gateway (also enforced as an
# Origin-header check on POST /runs). Default covers Vite dev on both localhost and 127.0.0.1
# spellings.
# FABRI_GATEWAY_CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Gateway listen port. Keep in sync with apps/studio/.env VITE_FABRI_GATEWAY_URL.
# FABRI_GATEWAY_PORT=8787

# Per-run sandboxes (uploaded videos + artifacts), fabri session homes, and sqlite memory.
# Relative paths resolve against integrations/fabri/ (the directory containing this file),
# regardless of cwd. Default integrations/fabri/runs, git-ignored. In Docker this is set to
# /data/runs on a volume.
# FABRI_RUNS_DIR=./runs

# Optional manual override forcing vid_ground_text onto its deterministic offline stub. The
# VALUE must be inline JSON containing box/boxes/point/points/chosen, or a path to a JSON
# fixture — NEVER a bare 1/0 (the tool json-parses the value; a bare int crashes it). Any
# non-empty value enables stub mode. Auto-set to the example JSON by the gateway when
# GEMINI_API_KEY is absent.
# WEBSAM_GROUND_TEXT_STUB={"point": {"x": 128, "y": 128}}

# docker compose only: your own BUSL fabri checkout, supplied at build time via a BuildKit
# named context, never vendored in this repo. Export in your shell (compose does not read
# this file for ${} substitution).
# FABRI_CHECKOUT=/path/to/fabri
