# Copy to .env (git-ignored). Vite only exposes VITE_-prefixed vars to the client; restart the dev server after editing.

# Base URL of the fabri video-editing gateway (integrations/fabri/service). Must match FABRI_GATEWAY_PORT in integrations/fabri/.env, and that gateway must allow this app's origin via FABRI_GATEWAY_CORS_ORIGIN (default allows http://localhost:5173 and http://127.0.0.1:5173). ChatPanel falls back to http://localhost:8787 when unset.
VITE_FABRI_GATEWAY_URL=http://localhost:8787

# Optional: base URL/path for EdgeTAM model weights (see src/segmentation/segmenter-lifecycle.ts).
# VITE_WEBSAM_MODELS=/models/edgetam/

# Optional: override onnxruntime-web .wasm asset location.
# VITE_ORT_WASM_PATHS=
